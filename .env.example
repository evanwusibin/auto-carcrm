# =========================
# 应用基础配置
# =========================
IMPORT_APP_NAME=Enterprise RAG Import Service
QUERY_APP_NAME=Enterprise RAG Query Service
APP_ENV=dev
APP_HOST=0.0.0.0
IMPORT_APP_PORT=8000
QUERY_APP_PORT=8001
CORS_ORIGINS=*

# =========================
# LLM / VL 模型配置
# 说明：
# 1. 本项目使用 OpenAI 兼容协议的任意中转服务（例如小米 token-plan、OpenRouter 等）
# 2. LLM_DEFAULT_TEMPERATURE 必须可被转换为 float
# =========================
OPENAI_BASE_URL=https://your-llm-endpoint/v1
OPENAI_API_KEY=sk-your-key
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_DEFAULT_TEMPERATURE=0.1
VL_MODEL=gpt-4o

# =========================
# Embedding 配置
# =========================
BGE_M3_PATH=./models/bge-m3
BGE_M3=BAAI/bge-m3
BGE_DEVICE=cpu
BGE_FP16=False

# =========================
# Reranker 配置
# =========================
BGE_RERANKER_LARGE=./models/bge-reranker-v2-m3
BGE_RERANKER_DEVICE=cpu
BGE_RERANKER_FP16=False

# =========================
# Milvus 配置
# =========================
MILVUS_URL=http://127.0.0.1:19530
CHUNKS_COLLECTION=kb_chunks
ENTITY_NAME_COLLECTION=kb_entities
ITEM_NAME_COLLECTION=kb_item_names

# =========================
# Mongo 配置
# MONGO_DB_NAME 为业务库；MONGO_KNOWLEDGE_DB 为知识库（不设则复用 MONGO_DB_NAME）
# =========================
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB_NAME=enterprise_rag
MONGO_KNOWLEDGE_DB=enterprise_rag_kb

# =========================
# MinIO 配置
# endpoint 不带 http/https，由代码内部配合 secure 使用
# MINIO_IMG_DIR 建议以 / 开头，例如 /kb-images
# =========================
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=enterprise-rag
MINIO_IMG_DIR=/kb-images
MINIO_SECURE=False

# =========================
# MinerU 配置
# =========================
MINERU_BASE_URL=https://your-mineru-endpoint
MINERU_API_TOKEN=your-mineru-token

# =========================
# DashScope MCP / WebSearch 配置
# 当前 node_web_search_mcp 固定走 DashScope WebSearch MCP
# MCP_DASHSCOPE_BASE_URL 当前代码未实际使用，但建议仍保留
# =========================
MCP_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/mcp

# =========================
# 项目根目录可选配置
# 如果未设置，代码会自动递归查找 .env
# =========================
PROJECT_ROOT=

# =========================
# JWT / 身份认证配置
# core/dependencies.py 使用，默认为 debug-user，生产环境必须修改 JWT_SECRET
# =========================
JWT_SECRET=please-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
# 高风险关键词，逗号分隔
DIAGNOSIS_RISK_HIGH_KEYWORDS=

# =========================
# RAG 检索与排序配置（rag_config.py）
# =========================
RAG_VECTOR_TOPK=20
RAG_KEYWORD_TOPK=10
RAG_CASE_TOPK=5
RAG_FINAL_TOPK=5
RAG_CONFIDENCE_THRESHOLD=0.55
RAG_RRF_K=60
RAG_MAX_CONTEXT_CHARS=10000

# =========================
# 日志配置
# =========================
LOG_CONSOLE_ENABLE=True
LOG_CONSOLE_LEVEL=INFO
LOG_FILE_ENABLE=True
LOG_FILE_LEVEL=INFO
LOG_FILE_RETENTION=7 days
